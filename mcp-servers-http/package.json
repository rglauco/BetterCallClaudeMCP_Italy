{
  "name": "@bettercallclaude-italia/http-aggregator",
  "version": "1.0.1",
  "description": "HTTP aggregator for BetterCallClaude Italia MCP servers",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "http",
    "aggregator",
    "italian-law"
  ],
  "author": "BetterCallClaude Associazione",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@bettercallclaude-italia/cassazione": "^1.0.0",
    "@bettercallclaude-italia/corte-costituzionale": "^1.0.0",
    "@bettercallclaude-italia/eur-lex-ita": "^1.0.0",
    "@bettercallclaude-italia/giustizia-amministrativa": "^1.0.0",
    "@bettercallclaude-italia/legal-citations-ita": "^1.0.0",
    "@bettercallclaude-italia/legal-persona-ita": "^1.0.0",
    "@bettercallclaude-italia/normattiva": "^1.0.0",
    "@bettercallclaude-italia/shared": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cors": "^2.8.6",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  }
}
