# BetterCallClaude Italia — Variabili d'ambiente

# Porta del server HTTP (Railway imposta questa automaticamente)
PORT=8080

# Base URL API Normattiva (produzione)
NORMATTIVA_API_BASE=https://api.normattiva.it/t/normattiva.api

# Rate limiting (opzionale — valori in millisecondi / richieste)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
MCP_RATE_LIMIT_MAX=30
HEALTH_RATE_LIMIT_MAX=60

# Environment
NODE_ENV=production
